# ── Supabase ────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Email (Resend) ──────────────────────────────────────────
# Transactional email for team registration (confirmation + admin
# notification) and review actions (approval / needs-info / rejection).
# Without RESEND_API_KEY, email is skipped (logged, non-blocking).
RESEND_API_KEY=
# Must be a domain verified in Resend, e.g. "Apex Academy <league@yourdomain.com>".
# The test sender onboarding@resend.dev only delivers to the Resend account owner.
EMAIL_FROM=Apex Academy <onboarding@resend.dev>
# Where new-registration notifications are sent.
ADMIN_EMAIL=apexsportsgg@gmail.com
